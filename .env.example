# PostgreSQL (runtime connection for Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pg?schema=public"

# PostgreSQL (direct connection for Prisma migrations)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pg?schema=public"

# Better Auth (https://www.better-auth.com/docs/installation)
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
